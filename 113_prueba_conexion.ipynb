    "import requests\n",
    "import pandas as pd\n",
    "\n",
    "#datos reales de la API de intercambio de monedas\n",
    "try: \n",
    "    url = \"https://api.exchangerate-api.com/v4/latest/USD\"\n",
    "    respuesta = requests.get(url)\n",
    "    datos = respuesta.json()\n",
    "except Exception as e:\n",
    "    print(f\"error en la conexión\")\n",
    "    \n",
    "#se crea un resumen de los tipos de cambio \n",
    "df = pd.DataFrame(datos[\"rates\"].items(), columns=[\"Moneda\", \"Valor\"])\n",
    "print(\" Conexion exitosa! Aqui los primeros datos capturados:\")\n",
    "print(df.head())\n"
   ]
